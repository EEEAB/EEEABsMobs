  "_comment": "Tips",
  "item.eeeabsmobs.remove_mob.tip_1": "Left-click to remove 'EEEAB's Mobs' mob/entity",
  "item.eeeabsmobs.remove_mob.tip_2": "Right-click to remove 'EEEAB's Mobs' mobs/entities in a 16x16x16 area",
  "item.eeeabsmobs.animation_controller.tip": "Left-click to select the animation entity and right-click to play the animation of the selected entity",
  "item.other.eeeabsmobs.animation_controller.tip": "Entity %1$s has been selected",
  "item.eeeabsmobs.guardian_core.tip_1": "Hold the right-click to release a laser, dealing 5 base damage plus 1% of the target's maximum health. \nIt continuously consumes the item's durability while in use, and when not in use, the durability automatically recovers while in the inventory",
  "item.eeeabsmobs.guardian_core.tip": "Attack range: §l[ %1$s §l]",
  "item.eeeabsmobs.buster_gauntlet.tip": "Right-click to fire a grenade, dealing up to %1$s explosive damage",
  "item.eeeabsmobs.chainsword.tip": "When there is no attack cooldown, dealing damage to the same type of target stacks 1 layer of Rend, increasing damage by %1$s per stack, up to %2$s stacks. Decays by 1 stack per second; switching targets resets the stack count",
  "item.eeeabsmobs.doombolt_battleaxe.tip": "Hold right-click to throw. Upon impact, it releases an area-of-effect surge and automatically returns. While crouching, right-click the ground to release multiple electric surges in a fan-shaped area ahead",
  "item.eeeabsmobs.heart_of_pagan.tip": "Used to make frenzy potions",
  "item.eeeabsmobs.soul_summon_necklace.tip": "Take damage accumulates to %1$s summon Corpse. Can counteract the side effects brought on by the Frenzy effect",
  "item.eeeabsmobs.immortal_sword.tip": "Gives the attacker the erosion status",
  "item.eeeabsmobs.immortal_staff.tip": "Right-click to launch a shaman bomb, with a 25% base chance to fire a special projectile (this base probability is affected by luck or bad luck)",
  "item.eeeabsmobs.guardian_axe.tip_1": "Sweep damage: §l[ %1$s §l]",
  "item.eeeabsmobs.guardian_axe.tip_2": "Right-click on the ground to release a skill that deals magic damage equal to the user's weapon damage (ignoring armor, with the damage decreasing over distance)",
  "item.structure.eeeabsmobs.eye_of_bloody_altar.tip": "Right-click to find the Bloody Altar structure",
  "item.structure.eeeabsmobs.eye_of_coreforge_ruins.tip": "Right-click to find the Coreforge Ruins structure",
